# EditorConfig — https://editorconfig.org
# Mirrors the formatters that actually gate CI: rustfmt (Rust, 4-space) and
# swift-format (Swift, 4-space). This file only helps editors that DON'T run
# those formatters; the formatters remain the source of truth. Keep these
# stanzas in sync if a formatter config changes. (The Biome TS/JS stanza died
# with the Node toolchain in #5 PR7 — the [*] 2-space default covers JSON.)

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Rust — rustfmt (4 spaces, max_width 100)
[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

# Swift — swift-format (.swift-format: 4 spaces, lineLength 100)
[*.swift]
indent_style = space
indent_size = 4
max_line_length = 100

# YAML — 2-space is the de-facto standard and what our workflows use
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Shell scripts — 2-space (scripts/*.sh)
[*.sh]
indent_style = space
indent_size = 2

# Markdown — preserve trailing whitespace (two-space hard line breaks)
[*.md]
trim_trailing_whitespace = false

# Makefiles require real tabs
[Makefile]
indent_style = tab
