{
  "expo": {
    "name": "Teleprompter",
    "slug": "teleprompter",
    "version": "1.0.0",
    "scheme": "teleprompter",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.teleprompter.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan QR codes for daemon pairing.",
        "NSMicrophoneUsageDescription": "Microphone is used for voice commands to control Claude Code.",
        "UISupportsDocumentBrowser": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.teleprompter.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-barcode-scanner",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "newArchEnabled": true
          },
          "android": {
            "minSdkVersion": 24,
            "newArchEnabled": true
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to scan QR codes for daemon pairing."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d10223aa-49ba-4dd6-8025-f7f6d723f6bf"
      }
    },
    "owner": "davedev42",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d10223aa-49ba-4dd6-8025-f7f6d723f6bf"
    }
  }
}
