{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_VARIANT": "dev-local",
        "EAS_BUILD_DISABLE_EXPO_DOCTOR_STEP": "1"
      }
    },
    "device": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "APP_VARIANT": "dev-local",
        "EAS_BUILD_DISABLE_EXPO_DOCTOR_STEP": "1"
      }
    },
    "preview": {
      "distribution": "store",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "ascAppId": "6761056150"
      },
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6761056150"
      },
      "android": {
        "track": "production"
      }
    }
  }
}
