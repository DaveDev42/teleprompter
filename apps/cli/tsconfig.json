{
  "extends": "@teleprompter/tsconfig/bun.json",
  "include": ["src"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@teleprompter/protocol": ["../../packages/protocol/src"],
      "@teleprompter/protocol/*": ["../../packages/protocol/src/*"],
