<?xml version="1.0" encoding="UTF-8"?>
<!--
  Mac App Store (TestFlight) export options for `TP_PLATFORM=macos scripts/ios.sh
  archive` (ADR-0004 §7 Amendment 1).

  Consumed by `xcodebuild -exportArchive -exportOptionsPlist`. This turns the
  signed macOS .xcarchive into a Mac-App-Store-uploadable .pkg (NOT an .ipa —
  the App Store Connect method for macOS emits a signed installer package).

  - method app-store-connect: the Xcode 15.4+ spelling of "app-store"
    (TestFlight + App Store). macOS MAS uses the same method as iOS; the .pkg
    output difference is driven by the macOS platform of the archive, not a
    different method string.
  - signingStyle manual: CI imports the Mac App Distribution cert + Mac App Store
    provisioning profile into a throwaway keychain; manual keeps xcodebuild from
    talking to the developer portal (impossible headlessly).
  - uploadSymbols true: ship dSYMs so App Store Connect symbolicates crash logs.

  teamID and the bundleId→profile mapping are NOT hardcoded — `cmd_archive` injects
  them at EXPORT time into a temp copy (ExportOptions.resolved.plist) from
  $TP_DEVELOPMENT_TEAM + ARCHIVE_PROFILE_MAP (macOS = one entry: dev.tpmt.app →
  "Teleprompter macOS App Store"). Manual -exportArchive does NOT resolve profiles
  from the keychain by bundle id — that is Automatic-signing behavior; manual needs
  an explicit provisioningProfiles dict. The .pkg is
  signed with the "3rd Party Mac Developer Installer" identity, which is a SEPARATE
  certificate from the app-signing identity (Apple portal lists them as distinct
  cert types). No installerSigningCertificate key is needed here as long as that
  installer identity is present in the keychain — the CI keychain imports it either
  from a combined .p12 or a separate MAC_INSTALLER_CERT_P12_BASE64 secret (see
  .github/workflows/testflight.yml + docs/testflight-setup.md §2).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store-connect</string>
    <key>signingStyle</key>
    <string>manual</string>
    <key>uploadSymbols</key>
    <true/>
    <key>destination</key>
    <string>export</string>
</dict>
</plist>
