{
  "name": "teleprompter",
  "private": true,
  "license": "BSD-2-Clause",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "build": "turbo run build",
    "build:cli": "bun run scripts/build.ts --all",
    "build:cli:local": "bun run scripts/build.ts",
    "dev": "turbo run dev",
    "test": "bun test ./packages/protocol ./packages/daemon ./packages/runner ./apps/cli ./packages/relay",
    "test:turbo": "turbo run test",
    "type-check": "turbo run type-check",
    "type-check:all": "npx tsc --noEmit -p packages/daemon/tsconfig.json && npx tsc --noEmit -p apps/cli/tsconfig.json && npx tsc --noEmit -p packages/relay/tsconfig.json && npx tsc --noEmit -p packages/runner/tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "doctor": "bun run apps/cli/src/index.ts doctor",
    "status": "bun run apps/cli/src/index.ts status",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "lefthook": "^2.1.9",
    "turbo": "^2.9.18",
    "typescript": "~6.0.3"
  },
  "version": "0.1.51"
}
