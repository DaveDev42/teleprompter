{
  "name": "teleprompter",
  "private": true,
  "license": "BSD-2-Clause",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "build:cli": "bun run scripts/build.ts --all",
    "build:cli:local": "bun run scripts/build.ts",
    "build:web": "cd apps/app && npx expo export --platform web",
    "dev": "turbo run dev",
    "dev:app": "cd apps/app && npx expo start --web",
    "test": "bun test packages/protocol packages/daemon packages/runner apps/cli packages/relay",
    "test:e2e": "npx playwright test --project=local",
    "test:e2e:ci": "npx playwright test --project=ci",
    "test:turbo": "turbo run test",
    "type-check": "turbo run type-check",
    "type-check:all": "npx tsc --noEmit -p packages/daemon/tsconfig.json && npx tsc --noEmit -p apps/cli/tsconfig.json && npx tsc --noEmit -p packages/relay/tsconfig.json && npx tsc --noEmit -p packages/runner/tsconfig.json && cd apps/app && npx tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "doctor": "bun run apps/cli/src/index.ts doctor",
    "status": "bun run apps/cli/src/index.ts status"
  },
  "pnpm": {
    "overrides": {
      "@expo/dom-webview": "55.0.5"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/mcp": "^0.0.69",
    "@playwright/test": "^1.58.2",
    "serve": "^14.2.6",
    "turbo": "^2.5.4"
  },
  "version": "0.1.11"
}
