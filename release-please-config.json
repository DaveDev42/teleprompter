{
  "packages": {
    ".": {
      "release-type": "node",
      "tag-prefix": "release/v",
      "include-component-in-tag": false,
      "bump-major-pre-major": false,
      "bump-minor-pre-major": false,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        {
          "type": "json",
          "path": "apps/app/app.json",
          "jsonpath": "$.expo.version"
        }
      ]
    }
  }
}
