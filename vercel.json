{
  "buildCommand": "cd apps/app && npx expo export --platform web",
  "installCommand": "pnpm install",
  "outputDirectory": "apps/app/dist",
  "framework": null,
  "rewrites": [
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    {
      "source": "/((?!_expo|assets|favicon\\.png|privacy-policy).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
